# =========================================================
# TDC Fine Counter 核心物理约束与时序豁免文件 (修复版)
# =========================================================

# ---------------------------------------------------------
# 1. 保护 CARRY4 原语本身不被优化
# ---------------------------------------------------------
set_property DONT_TOUCH true [get_cells -hierarchical -filter {REF_NAME == CARRY4 && NAME =~ *carry4_rising_inst*}]
set_property DONT_TOUCH true [get_cells -hierarchical -filter {REF_NAME == CARRY4 && NAME =~ *carry4_falling_inst*}]

# (注意：线网的 DONT_TOUCH 已经转移到 Verilog 的 keep 属性中了，这里删除了)

# ---------------------------------------------------------
# 2. 异步时序豁免 (FALSE PATH) - 终极无死角语法
# ---------------------------------------------------------
# 豁免外部 PWM 异步输入
set_false_path -from [get_ports pwm_signal]

# 【核心修复】：不指定无效的起点，直接宣告“所有终点在这组采样寄存器上的路径，全都不看时序！”
# 这完美契合了 TDC 的异步采样本质。
set_false_path -to [get_cells -hierarchical -filter {NAME =~ *sampled_chain_a_reg*}]
set_false_path -to [get_cells -hierarchical -filter {NAME =~ *sampled_chain_b_reg*}]

# 定义 50MHz 板载主时钟
#create_clock -period 20.000 -name sys_clk [get_ports sys_clk]
set_property CLOCK_DEDICATED_ROUTE FALSE [get_nets pwm_signal_IBUF]

# 引脚绑定 (根据你的开发板原理图)
set_property -dict {PACKAGE_PIN R4 IOSTANDARD LVCMOS15} [get_ports sys_clk]
set_property -dict {PACKAGE_PIN U7 IOSTANDARD LVCMOS15} [get_ports sys_rst_n]
set_property -dict {PACKAGE_PIN T16 IOSTANDARD LVCMOS33} [get_ports pwm_signal]
set_property -dict {PACKAGE_PIN V9 IOSTANDARD LVCMOS15} [get_ports {led_out[0]}]
set_property -dict {PACKAGE_PIN Y8 IOSTANDARD LVCMOS15} [get_ports {led_out[1]}]
set_property -dict {PACKAGE_PIN Y7 IOSTANDARD LVCMOS15} [get_ports {led_out[2]}]
set_property -dict {PACKAGE_PIN W7 IOSTANDARD LVCMOS15} [get_ports {led_out[3]}]


#系统生成的约束文件中，工具会自动将寄存器放在默认位置，可能导致时序不理想。以下是针对采样寄存器和 CARRY4 模块的具体布局约束，确保它们被放置在靠近 CARRY4 的位置

set_property LOC SLICE_X52Y76 [get_cells -hierarchical -filter {NAME =~ *rising_delay_chain[0]*carry4*}]
set_property -dict {LOC SLICE_X52Y76 BEL AFF} [get_cells -hierarchical -filter {NAME =~ *sampled_chain_a_reg[0]*}]
