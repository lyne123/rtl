# =========================================================
# TDC 绝对物理锁定 (LOC & BEL 自动化脚本)
# 开启"上帝模式"，强制指定每一个 CARRY4 和触发器的绝对位置
# =========================================================
# ---------------------------------------------------------
# 1. 锁定上升沿延迟链 (强制在 X10 列，从 Y0 到 Y19)
# ---------------------------------------------------------
set start_x_rise 10
10
set start_y 0
0
for {set i 0} {$i < 20} {incr i} {
    set current_y [expr $start_y + $i]
    set target_slice "SLICE_X${start_x_rise}Y${current_y}"
    
    set r0 [expr $i * 4 + 0]
    set r1 [expr $i * 4 + 1]
    set r2 [expr $i * 4 + 2]
    set r3 [expr $i * 4 + 3]

    # 使用 filter 配合双引号，防止 Tcl 中括号解析错误
    set carry_cell [get_cells -hierarchical -filter "NAME =~ *rising_delay_chain\[${i}\]*carry4*"]
    set reg_0 [get_cells -hierarchical -filter "NAME =~ *sampled_chain_a_reg\[${r0}\]*"]
    set reg_1 [get_cells -hierarchical -filter "NAME =~ *sampled_chain_a_reg\[${r1}\]*"]
    set reg_2 [get_cells -hierarchical -filter "NAME =~ *sampled_chain_a_reg\[${r2}\]*"]
    set reg_3 [get_cells -hierarchical -filter "NAME =~ *sampled_chain_a_reg\[${r3}\]*"]

    # 锁定 CARRY4 的 Slice 位置
    set_property LOC $target_slice $carry_cell

    # 锁定 4 个寄存器的 Slice 位置
    set_property LOC $target_slice $reg_0
    set_property LOC $target_slice $reg_1
    set_property LOC $target_slice $reg_2
    set_property LOC $target_slice $reg_3

    # 锁定 4 个寄存器的具体槽位 (BEL)
    set_property BEL AFF $reg_0
    set_property BEL BFF $reg_1
    set_property BEL CFF $reg_2
    set_property BEL DFF $reg_3
}
