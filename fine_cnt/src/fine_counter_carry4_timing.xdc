# # =========================================================
# # TDC Fine Counter әЛРДОпАнФјКшУлКұРт»нГвОДјю
# # =========================================================

# # ---------------------------------------------------------
# # 1. ұЈ»ӨәЛРДВЯјӯІ»ұ»УЕ»Ҝөф (DONT_TOUCH)
# # ---------------------------------------------------------
# # ұЈ»Ө CARRY4 ФӯУпұҫЙн
# set_property DONT_TOUCH true [get_cells -hierarchical *carry4_rising_inst*]
# set_property DONT_TOUCH true [get_cells -hierarchical *carry4_falling_inst*]

# # ұЈ»ӨСУіЩБҙійН·әНЧЁУГј¶БӘПЯ (ЧўТвЈәТСёщҫЭЧоРВҙъВлРЮёДОӘ carry_cascade)
# set_property DONT_TOUCH true [get_nets -hierarchical *carry_cascade_a*]
# set_property DONT_TOUCH true [get_nets -hierarchical *carry_cascade_b*]
# set_property DONT_TOUCH true [get_nets -hierarchical *delay_chain_a*]
# set_property DONT_TOUCH true [get_nets -hierarchical *delay_chain_b*]

# # ---------------------------------------------------------
# # 2. ТмІҪКұРт»нГв (FALSE PATH) - ·АЦ№ Vivado ВТЗЈәмПЯ
# # ---------------------------------------------------------
# # »нГв PWM ТмІҪКдИлВ·ҫ¶
# set_false_path -from [get_ports pwm_signal]

# # »нГвҙУ CARRY4 ҪшО»Кдіц (CO) өҪІЙСщјДҙжЖч (D¶Л) өДҙҝТмІҪҝзКұЦУВ·ҫ¶
# set_false_path -from [get_pins -hierarchical *carry4_rising_inst/CO[*]] -to [get_pins -hierarchical *sampled_chain_a_reg[*]/D]
# set_false_path -from [get_pins -hierarchical *carry4_falling_inst/CO[*]] -to [get_pins -hierarchical *sampled_chain_b_reg[*]/D]

# # ---------------------------------------------------------
# # 3. ОпАнО»ЦГФјКш (PBLOCK) - TDC өДБй»кЈ¬ұЈЦӨЖӨГлј¶ПЯРФ¶И
# # ---------------------------------------------------------
# # Лш¶ЁЙПЙэСШСУіЩБҙ (ЗҝЦЖ°С CARRY4 әН ІЙСщҙҘ·ўЖч ҝтФЪН¬Т»ёцЗшУтДЪ)
# create_pblock PBLOCK_TDC_RISE
# add_cells_to_pblock [get_pblocks PBLOCK_TDC_RISE] [get_cells -hierarchical *rising_delay_chain*]
# add_cells_to_pblock [get_pblocks PBLOCK_TDC_RISE] [get_cells -hierarchical *sampled_chain_a_reg*]
# # ЧўТвЈәДгРиТӘЧФјәИҘ Device КУНјХТТ»БРҝХөД 20 ёц Slice МоФЪХвАп
# resize_pblock [get_pblocks PBLOCK_TDC_RISE] -add {SLICE_X1Y0:SLICE_X1Y19}

# # Лш¶ЁПВҪөСШСУіЩБҙ (Ҫф°ӨЧЕЙПЙэСШ·ЕЕФұЯБнТ»БР)
# create_pblock PBLOCK_TDC_FALL
# add_cells_to_pblock [get_pblocks PBLOCK_TDC_FALL] [get_cells -hierarchical *falling_delay_chain*]
# add_cells_to_pblock [get_pblocks PBLOCK_TDC_FALL] [get_cells -hierarchical *sampled_chain_b_reg*]
# resize_pblock [get_pblocks PBLOCK_TDC_FALL] -add {SLICE_X2Y0:SLICE_X2Y19}

# # ---------------------------------------------------------
# # 4. ПөНіКұЦУУл IO №ЬҪЕФјКш (јЩЙиЧчУГУЪ¶ҘІгДЈҝй)
# # ---------------------------------------------------------
# # ¶ЁТе 50MHz °еФШЦчКұЦУ
# create_clock -period 20.000 -name sys_clk [get_ports sys_clk]

# # ТэҪЕ°у¶Ё (ёщҫЭДгөДҝӘ·ў°еФӯАнНј)
# set_property -dict {PACKAGE_PIN R4 IOSTANDARD LVCMOS15} [get_ports sys_clk]
# set_property -dict {PACKAGE_PIN U7 IOSTANDARD LVCMOS15} [get_ports rst_n]
# set_property -dict {PACKAGE_PIN T16 IOSTANDARD LVCMOS33} [get_ports pwm_signal]
# set_property -dict {PACKAGE_PIN V9 IOSTANDARD LVCMOS15} [get_ports valid_out]

# =========================================================
# TDC Fine Counter әЛРДОпАнФјКшУлКұРт»нГвОДјю (РЮёҙ°ж)
# =========================================================

# ---------------------------------------------------------
# 1. ұЈ»Ө CARRY4 ФӯУпұҫЙнІ»ұ»УЕ»Ҝ
# ---------------------------------------------------------
set_property DONT_TOUCH true [get_cells -hierarchical -filter {REF_NAME == CARRY4 && NAME =~ *carry4_rising_inst*}]
set_property DONT_TOUCH true [get_cells -hierarchical -filter {REF_NAME == CARRY4 && NAME =~ *carry4_falling_inst*}]

# (ЧўТвЈәПЯНшөД DONT_TOUCH ТСҫӯЧӘТЖөҪ Verilog өД keep КфРФЦРБЛЈ¬ХвАпЙҫіэБЛ)

# ---------------------------------------------------------
# 2. ТмІҪКұРт»нГв (FALSE PATH) - ЦХј«ОЮЛАҪЗУп·Ё
# ---------------------------------------------------------
# »нГвНвІҝ PWM ТмІҪКдИл
set_false_path -from [get_ports pwm_signal]

# ЎҫәЛРДРЮёҙЎҝЈәІ»Цё¶ЁОЮР§өДЖрөгЈ¬ЦұҪУРыёжЎ°ЛщУРЦХөгФЪХвЧйІЙСщјДҙжЖчЙПөДВ·ҫ¶Ј¬И«¶јІ»ҝҙКұРтЈЎЎұ
# ХвНкГАЖхәПБЛ TDC өДТмІҪІЙСщұҫЦКЎЈ
set_false_path -to [get_cells -hierarchical -filter {NAME =~ *sampled_chain_a_reg*}]
set_false_path -to [get_cells -hierarchical -filter {NAME =~ *sampled_chain_b_reg*}]

# ---------------------------------------------------------
# 3. ОпАнО»ЦГФјКш (PBLOCK)
# ---------------------------------------------------------
# Лш¶ЁЙПЙэСШСУіЩБҙ

# Лш¶ЁПВҪөСШСУіЩБҙ

# ¶ЁТе 50MHz °еФШЦчКұЦУ
#create_clock -period 20.000 -name sys_clk [get_ports sys_clk]

# ТэҪЕ°у¶Ё (ёщҫЭДгөДҝӘ·ў°еФӯАнНј)
set_property -dict {PACKAGE_PIN R4 IOSTANDARD LVCMOS15} [get_ports sys_clk]
set_property -dict {PACKAGE_PIN U7 IOSTANDARD LVCMOS15} [get_ports sys_rst_n]
set_property -dict {PACKAGE_PIN T16 IOSTANDARD LVCMOS33} [get_ports pwm_signal]
set_property -dict {PACKAGE_PIN V9 IOSTANDARD LVCMOS15} [get_ports valid_out]


set_property BEL AFF [get_cells -hierarchical -filter {NAME =~ *sampled_chain_a_reg[0]*}]
set_property BEL BFF [get_cells -hierarchical -filter {NAME =~ *sampled_chain_a_reg[1]*}]
set_property BEL CFF [get_cells -hierarchical -filter {NAME =~ *sampled_chain_a_reg[2]*}]
set_property BEL DFF [get_cells -hierarchical -filter {NAME =~ *sampled_chain_a_reg[3]*}]
set_property LOC SLICE_X0Y0 [get_cells -hierarchical -filter {NAME =~ *rising_delay_chain[0]*carry4*}]
set_property LOC SLICE_X1Y0 [get_cells -hierarchical -filter {NAME =~ *sampled_chain_a_reg[0]*}]
